# =============================================================================
# Sensitive Data Protection — CRITICAL
# =============================================================================
# Claude Code local configurations (contain live API tokens)
.claude/*.local.json
.claude/.edit-guard-state.json
.claude/.harness-state
.claude/reviews/
.claude/loops/

# Codex local config (may contain API keys/tokens)
.codex/config.toml
.codex/hooks.json

# =============================================================================
# Generated by Cargo
# =============================================================================
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
**/mutants.out*/

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
.DS_Store

# =============================================================================
# Environment / Secrets
# =============================================================================
.env
.env.*
!.env.example
!.env.template

*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.*
*.keytab

# =============================================================================
# Build Artifacts / Logs
# =============================================================================
dist/
build/
out/
*.log
logs/
core
*.core
.cache/
*.cache

# =============================================================================
# OS Files
# =============================================================================
Thumbs.db
desktop.ini

# =============================================================================
# Un-ignore exceptions
# =============================================================================
!README.md
!.gitmessage
